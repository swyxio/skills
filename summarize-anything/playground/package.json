{
  "name": "summarize-playground",
  "private": true,
  "scripts": {
    "dev:server": "bun run --hot server.ts",
    "dev:css": "bunx @tailwindcss/cli -i src/app.css -o dist/app.css --watch",
    "dev:js": "bun build src/index.tsx --outdir dist --target browser --watch",
    "dev": "bun run dev:css & bun run dev:js & bun run dev:server",
    "build:css": "bunx @tailwindcss/cli -i src/app.css -o dist/app.css --minify",
    "build:js": "bun build src/index.tsx --outdir dist --target browser --minify",
    "build": "bun run build:css && bun run build:js"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  }
}
